@model Wine_Store_Management_Web.Models.PhieuBaoHanhKho

@{
    ViewData["Title"] = "BH_BM5 - Phiếu Bảo Hành";
}

<div class="container mt-4 d-flex justify-content-center">
    <div class="card shadow-sm" style="width: 600px; border: 2px dashed #000;">
        <div class="card-body p-4">
            <h5 class="text-center fw-bold m-0">CỬA HÀNG RƯỢU CHILLIQUER</h5>
            <hr style="border-top: 2px dashed #000;" />
            <h4 class="text-center fw-bold">PHIẾU BẢO HÀNH</h4>
            <p class="text-center small text-muted">(Kết xuất dữ liệu hệ thống - Mẫu BH_BM05)</p>

            <form asp-action="Create" method="post">
                <div class="mb-3">
                    <label class="fw-bold">Mã phiếu:</label>
                    <input asp-for="MaPhieuBH" class="form-control border-bottom-only d-inline w-75" placeholder="PBH-2026-................" />
                </div>

                <div class="row g-2 mb-2">
                    <div class="col-8">
                        <label class="fw-bold">- Khách hàng:</label>
                        <input asp-for="MaKhachHang" class="form-control border-bottom-only w-100" placeholder="................................................" />
                    </div>
                    <div class="col-4">
                        <label class="fw-bold">SĐT:</label>
                        <input type="text" class="form-control border-bottom-only w-100" placeholder="..........................." readonly />
                    </div>
                </div>

                <div class="mb-2">
                    <label class="fw-bold">- Sản phẩm xử lý:</label>
                    <input asp-for="MaSanPham" class="form-control border-bottom-only w-100" placeholder="..............................................................................." />
                </div>

                <div class="mb-2">
                    <label class="fw-bold">- Số Seri/Mã vạch:</label>
                    <input asp-for="SoSeri" class="form-control border-bottom-only w-100" placeholder=".............................................................................." />
                </div>

                <div class="mb-2">
                    <label class="fw-bold">- Nội dung lỗi ghi nhận:</label>
                    <input asp-for="NoiDungLoiGhiNhan" class="form-control border-bottom-only w-100" placeholder="....................................................................." />
                </div>

                <div class="mb-2">
                    <label class="fw-bold">- Ngày tiếp nhận hệ thống:</label>
                    <input asp-for="NgayTiepNhanHeThong" type="date" class="form-control border-bottom-only d-inline w-50" />
                </div>

                <div class="mb-2 d-flex align-items-center">
                    <label class="fw-bold me-2">- Thời gian xử lý dự kiến:</label>
                    <input asp-for="ThoiGianXuLyDuKien" type="number" class="form-control border-bottom-only text-center" style="width: 80px;" />
                    <span class="ms-2">ngày.</span>
                </div>

                <div class="mb-4">
                    <label class="fw-bold">- Ngày hẹn trả sản phẩm:</label>
                    <input asp-for="NgayHenTra" type="date" class="form-control border-bottom-only d-inline w-50" />
                </div>

                <p class="fst-italic small">* Quý khách vui lòng xuất trình phiếu này khi đến nhận lại sản phẩm.</p>
                <hr style="border-top: 2px dashed #000;" />

                <div class="d-flex justify-content-between align-items-center">
                    <small>Hệ thống kết xuất tự động |</small>
                    <div>
                        <label class="fw-bold small">Nhân viên thực hiện:</label>
                        <input asp-for="NhanVienThucHien" class="form-control form-control-sm border-bottom-only d-inline" style="width: 150px;" value="@User.Identity?.Name" readonly />
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary">Xác nhận Kết xuất</button>
                </div>
            </form>
        </div>
    </div>
</div>