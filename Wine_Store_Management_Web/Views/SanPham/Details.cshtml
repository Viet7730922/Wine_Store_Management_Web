@model Wine_Store_Management_Web.Models.Sanpham

@{
    ViewData["Title"] = "KHO_BM1 - Phiếu Thêm Sản Phẩm Mới";
    Layout = null;
}

<!DOCTYPE html>
<html lang="vi">
<head>
    <meta charset="utf-8" />
    <title>PHIẾU THÊM SẢN PHẨM MỚI - @Model.MaSanPham</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
            body {
                font-family: 'Times New Roman', Times, serif;
                color: #000;
                margin: 0;
                padding: 30px;
                font-size: 16px;
            }

            .container {
                max-width: 900px;
                margin: 0 auto;
                border: 2px solid #000;
                padding: 30px;
            }

            .dotted-line {
                border-bottom: 1px dotted #000;
                display: inline-block;
                width: 70%;
                min-width: 300px;
            }

            .no-print {
                display: block !important;
            }

            @@media print {
                .no-print {
                    display: none !important;
                }

                .container {
                    border: none;
                    padding: 20px;
                }
            }
    </style>
</head>
<body>
    <div class="container">

        <div class="text-center mb-4">
            <h3 class="fw-bold text-uppercase">PHIẾU THÊM SẢN PHẨM MỚI</h3>
        </div>

        <div class="mb-3">
            <strong>Mã sản phẩm:</strong> <span class="dotted-line">@Model.MaSanPham</span>
        </div>
        <div class="mb-3">
            <strong>Tên sản phẩm:</strong> <span class="dotted-line">@Model.TenSanPham</span>
        </div>
        <div class="mb-3">
            <strong>Số seri sản phẩm:</strong> <span class="dotted-line">@Model.SoSeri</span>
        </div>
        <div class="mb-3">
            <strong>Loại sản phẩm:</strong> <span class="dotted-line">@Model.LoaiSanPham</span>
        </div>
        <div class="mb-3">
            <strong>Hãng sản xuất:</strong> <span class="dotted-line">@Model.HangSanXuat</span>
        </div>
        <div class="mb-3">
            <strong>Xuất xứ:</strong> <span class="dotted-line">@Model.XuatXu</span>
        </div>
        <div class="mb-3">
            <strong>Đơn vị tính:</strong> <span class="dotted-line">@Model.DonViTinh</span>
        </div>
        <div class="mb-3">
            <strong>Giá nhập:</strong>
            <span class="dotted-line">@(Model.GiaNhap > 0 ? Model.GiaNhap.ToString("N0") + " VNĐ" : "")</span>
        </div>
        <div class="mb-3">
            <strong>Giá bán đề xuất:</strong>
            <span class="dotted-line">@(Model.GiaBanDeXuat > 0 ? Model.GiaBanDeXuat.ToString("N0") + " VNĐ" : "")</span>
        </div>
        <div class="mb-3">
            <strong>Thời hạn bảo hành:</strong>
            <span class="dotted-line">@(Model.ThoiHanBaoHanh > 0 ? Model.ThoiHanBaoHanh + " tháng" : "")</span>
        </div>
        <div class="mb-4">
            <strong>Mô tả sản phẩm:</strong>
            <div class="border p-3 mt-2" style="min-height: 100px;">@(string.IsNullOrEmpty(Model.MoTa) ? "" : Model.MoTa)</div>
        </div>

        <div class="row mt-5">
            <div class="col-6">
                <strong>Người lập phiếu:</strong> <span class="dotted-line">@Model.NguoiLapPhieu</span>
            </div>
            <div class="col-6 text-end">
                <strong>Ngày tạo:</strong>
                <span class="dotted-line">@(Model.NgayTao.ToString("dd/MM/yyyy"))</span>
            </div>
        </div>

        <!-- 2 NÚT -->
        <div class="text-center mt-5 no-print">
            <button onclick="window.print()" class="btn btn-success px-5 py-3 fw-bold me-4">
                🖨 Xuất in ấn
            </button>
            <a asp-action="Index" class="btn btn-secondary px-5 py-3 fw-bold">
                📋 Danh sách sản phẩm
            </a>
        </div>

    </div>
</body>
</html>