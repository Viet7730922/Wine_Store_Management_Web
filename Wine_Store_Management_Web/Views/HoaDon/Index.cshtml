@model IEnumerable<Wine_Store_Management_Web.Models.HoaDon>

@{
    ViewData["Title"] = "Lịch sử Hóa đơn (BH_BM1)";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="text-danger">LỊCH SỬ HÓA ĐƠN BÁN HÀNG</h3>
        <a asp-action="Create" class="btn btn-danger"><i class="bi bi-cart-plus"></i> Lập Hóa Đơn Mới</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover table-bordered align-middle text-center">
                <thead class="table-danger">
                    <tr>
                        <th>Số Hóa Đơn</th>
                        <th>Ngày Lập</th>
                        <th>Người Mua Hàng</th>
                        <th>Khách Hàng (Mã Thẻ)</th>
                        <th>Thanh Toán</th>
                        <th>Thu Ngân</th>
                        <th>Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.SoHoaDon</td>
                            <td>@item.NgayHoaDon.ToString("dd/MM/yyyy")</td>
                            <td class="text-start">@item.HoTenNguoiMua</td>
                            <td>@(item.MaKhachHang ?? "Khách lẻ")</td>
                            <td>
                                <span class="badge @(item.HinhThucThanhToan == "Tiền mặt" ? "bg-warning text-dark" : "bg-info text-dark")">@item.HinhThucThanhToan</span>
                            </td>
                            <td>@item.ThuNgan</td>
                            <td>
                                <a asp-action="Details" asp-route-id="@item.SoHoaDon" class="btn btn-sm btn-outline-danger">
                                    <i class="bi bi-eye"></i> Chi tiết
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>