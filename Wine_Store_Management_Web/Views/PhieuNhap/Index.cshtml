@model IEnumerable<Wine_Store_Management_Web.Models.PhieuNhap>

@{
    ViewData["Title"] = "Lịch sử Nhập kho (KHO_BM2)";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="text-success">LỊCH SỬ PHIẾU NHẬP KHO</h3>
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Tạo Phiếu Nhập</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover table-bordered align-middle text-center">
                <thead class="table-success">
                    <tr>
                        <th>Mã Phiếu Nhập</th>
                        <th>Ngày Nhập</th>
                        <th>Nhà Cung Cấp</th>
                        <th>Nhập Tại Kho</th>
                        <th>Người Nhập</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.MaPhieuNhap</td>
                            <td>@item.NgayNhap.ToString("dd/MM/yyyy")</td>
                            <td class="text-start">@item.NhaCungCap</td>
                            <td>@item.NhapTaiKho</td>
                            <td>@item.NguoiNhapKho</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>