@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "QLCH_BM6 - Hiệu Suất Nhân Viên";
}

<div class="container mt-4">
    <div class="card shadow border-info">
        <div class="card-body p-5">
            <h4 class="text-center fw-bold mb-4 text-info text-darken">BÁO CÁO THỐNG KÊ HIỆU SUẤT BÁN HÀNG CỦA NHÂN VIÊN</h4>

            <form method="get" class="row justify-content-center mb-4 d-print-none">
                <div class="col-auto d-flex align-items-center">
                    <label class="fw-bold me-2">Chọn Tháng/Năm:</label>
                    <input type="month" name="kyThongKe" class="form-control" value="@ViewBag.KyThongKe_Input" required />
                    <button type="submit" class="btn btn-info text-white ms-2">Xem báo cáo</button>
                </div>
            </form>

            <div class="row mb-4">
                <div class="col-6">
                    <label class="fw-bold">Kỳ thống kê:</label>
                    <span class="border-bottom-only px-3">Tháng @ViewBag.Thang / Năm @ViewBag.Nam</span>
                </div>
                <div class="col-6 text-end">
                    <label class="fw-bold">Người lập tổng hợp:</label>
                    <span class="border-bottom-only px-3">@User.Identity?.Name</span>
                </div>
            </div>

            <h6 class="fw-bold text-decoration-underline mb-3">BẢNG XẾP HẠNG HIỆU SUẤT NHÂN VIÊN:</h6>
            <table class="table table-bordered table-hover align-middle text-center">
                <thead class="table-info">
                    <tr>
                        <th style="width: 5%">STT</th>
                        <th style="width: 15%">Mã nhân viên</th>
                        <th>Họ và tên</th>
                        <th style="width: 15%">Chức vụ</th>
                        <th style="width: 10%">Số ca trực</th>
                        <th style="width: 15%">Số hóa đơn đã lập</th>
                        <th style="width: 20%">Doanh số mang lại (VNĐ)</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int stt = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@stt</td>
                                <td class="fw-bold">@item.MaNhanVien</td>
                                <td class="text-start">@item.HoTen</td>
                                <td>Thu ngân</td>
                                <td>@item.SoCaTruc</td>
                                <td>@item.SoHoaDonLap</td>
                                <td class="text-end fw-bold text-primary">@item.DoanhSo.ToString("N2")</td>
                            </tr>
                            stt++;
                        }
                    }
                    else
                    {
                        <tr><td colspan="7" class="text-muted py-3">Không có giao dịch nào được ghi nhận trong kỳ này</td></tr>
                    }
                </tbody>
            </table>

            <div class="row text-center mt-5">
                <div class="col-5 offset-7">
                    <p class="m-0">Ngày @DateTime.Now.Day tháng @DateTime.Now.Month năm @DateTime.Now.Year</p>
                    <p class="fw-bold m-0 mt-2">Quản lý cửa hàng</p>
                    <small class="text-muted d-block mb-4">(Ký, họ tên)</small>
                    <span class="border-bottom-only w-75 d-inline-block"></span>
                </div>
            </div>

            <div class="text-center mt-4 d-print-none border-top pt-3">
                <button onclick="window.print()" class="btn btn-outline-info px-4"><i class="bi bi-printer"></i> In Bảng Xếp Hạng</button>
            </div>
        </div>
    </div>
</div>
<style>
    .text-darken {
        color: #0dcaf0;
        filter: brightness(0.8);
    }

    .border-bottom-only {
        border: none;
        border-bottom: 1px dotted #000;
        background: transparent;
        border-radius: 0;
    }
</style>