@model IEnumerable<Wine_Store_Management_Web.Models.Sanpham>

@{
    ViewData["Title"] = "Danh sách Sản phẩm (KHO_BM1)";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="text-primary">DANH SÁCH SẢN PHẨM</h3>
        <a asp-action="Create" class="btn btn-success"><i class="bi bi-plus-circle"></i> Thêm sản phẩm mới</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover table-bordered align-middle text-center">
                <thead class="table-primary">
                    <tr>
                        <th>Mã SP</th>
                        <th>Tên Sản Phẩm</th>
                        <th>Loại</th>
                        <th>ĐVT</th>
                        <th>Tồn Kho</th>
                        <th>Giá Bán (VNĐ)</th>
                        <th>Trạng Thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.MaSanPham</td>
                            <td class="text-start">@item.TenSanPham</td>
                            <td>@item.LoaiSanPham</td>
                            <td>@item.DonViTinh</td>
                            <td>
                                <span class="badge @(item.SoLuongTon > 0 ? "bg-success" : "bg-danger")">
                                    @item.SoLuongTon
                                </span>
                            </td>
                            <td class="text-end">@item.GiaBanDeXuat.ToString("N2")</td>
                            <td>@item.TrangThai</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>