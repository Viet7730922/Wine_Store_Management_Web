@model Wine_Store_Management_Web.Models.BiennhanGiaodich

@{
    ViewData["Title"] = "In Biên Nhận BH_BM6";
}

<div class="container my-5 d-flex justify-content-center">
    <div style="width: 700px;">
        <div class="p-5 bg-white border border-dark position-relative shadow-sm" style="font-family: 'Times New Roman', Times, serif; color: #000;">

            <h4 class="text-center fw-bold mb-3 mt-2 text-uppercase" style="letter-spacing: 1px;">BIÊN NHẬN ĐỔI TRẢ HOẶC GIAO DỊCH</h4>
            <p class="text-center mb-4" style="font-size: 1.1rem;">
                Ngày in: <span class="border-dotted px-3">@Model.NgayIn.ToString("dd/MM/yyyy")</span>
                Giờ: <span class="border-dotted px-3">@Model.GioIn.ToString("HH:mm")</span>
            </p>

            <div class="mb-3 d-flex align-items-center" style="font-size: 1.1rem;">
                <span class="me-3">Loại biên nhận:</span>
                <span class="fs-5 me-1 fw-bold">@(Model.LoaiBienNhan == "Đơn hàng chờ giao" ? "[ x ]" : "[   ]")</span>
                <span class="me-4">Đơn hàng chờ giao</span>
                <span class="fs-5 me-1 fw-bold">@(Model.LoaiBienNhan == "Biên nhận lấy hàng bảo hành" ? "[ x ]" : "[   ]")</span>
                <span>Biên nhận lấy hàng bảo hành</span>
            </div>

            <div class="mb-4 d-flex align-items-start" style="font-size: 1.1rem;">
                <span class="text-nowrap mt-1">Mã đối chiếu hệ thống:</span>
                <div class="border-dotted flex-grow-1 ps-2 fw-bold text-danger pb-1">@Model.MaDoiChieuHeThong</div>
            </div>

            <h6 class="fw-bold text-uppercase mb-3" style="font-size: 1.1rem;">NỘI DUNG BIÊN NHẬN:</h6>

            <div class="space-y-fields" style="line-height: 2.3; font-size: 1.1rem;">
                <div class="d-flex align-items-start">
                    <span class="text-nowrap mt-1">- Tên khách hàng:</span>
                    <div class="border-dotted flex-grow-1 ps-2 fw-bold pb-1">@Model.TenKhachHang</div>
                </div>

                <div class="d-flex mt-1 align-items-start">
                    <span class="text-nowrap mt-1">- Số điện thoại:</span>
                    <div class="border-dotted flex-grow-1 ps-2 pb-1">@Model.SoDienThoai</div>
                </div>

                <div class="d-flex mt-1 align-items-start">
                    <span class="text-nowrap mt-1">- Chi tiết sản phẩm/Nội dung bàn giao:</span>
                    <div class="border-dotted flex-grow-1 ps-2 fst-italic pb-1" style="min-height: 2.3rem;">
                        @Model.ChiTietSanPham
                    </div>
                </div>

                <div class="d-flex mt-3 align-items-center">
                    <span class="text-nowrap">- Tổng giá trị đối chiếu (nếu có):</span>
                    <div class="border-dotted text-end px-2 fw-bold" style="min-width: 150px;">
                        @(Model.TongGiaTriDoiChieu > 0 ? Model.TongGiaTriDoiChieu?.ToString("N0") : "...................")
                    </div>
                    <span class="ms-2">VNĐ</span>

                </div>
            </div>

            <p class="mt-4 mb-3" style="font-size: 1.1rem;">Biên nhận dùng để giao cho khách đối chiếu khi nhận hàng.</p>

            <div style="border-top: 2px dashed #000; margin: 15px 0;"></div>

            <div class="d-flex align-items-end mt-3" style="font-size: 1.1rem;">
                <span class="text-nowrap mb-1">Người xuất phiếu (Thu ngân):</span>
                <div class="border-dotted flex-grow-1 ps-2 text-center fw-bold pb-1">@Model.ThuNganXuatPhieuNavigation?.HoTen</div>
            </div>
        </div>

        <div class="text-center mt-4 d-print-none">
            <button onclick="window.print()" class="btn btn-dark px-5 py-2 fw-bold"><i class="bi bi-printer"></i> In Biên Nhận BH_BM6</button>
        </div>
    </div>
</div>

<style>
    .border-dotted {
        border-bottom: 1px dotted #000;
    }

    @@media print {
        header, footer, .d-print-none {
            display: none !important;
        }

        .container {
            max-width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        .border {
            border: none !important;
        }
    }
</style>