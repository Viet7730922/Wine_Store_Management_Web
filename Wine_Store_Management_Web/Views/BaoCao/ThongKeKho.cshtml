@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "KHO_BM3 - Báo Cáo Thống Kê Kho";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-body p-5">
            <h4 class="text-center fw-bold mb-1">Báo Cáo Thống Kê Kho</h4>
            <p class="text-center mb-1">Mã biểu mẫu: KHO_BM3</p>
            <p class="text-center mb-4">Thời gian báo cáo: @ViewBag.TuNgay đến @ViewBag.DenNgay</p>

            <form method="get" class="mb-4 d-flex justify-content-center">
                <div class="input-group w-50">
                    <span class="input-group-text">Từ ngày</span>
                    <input type="date" name="tuNgay" class="form-control" value="@ViewBag.TuNgay_Input" required />
                    <span class="input-group-text">Đến ngày</span>
                    <input type="date" name="denNgay" class="form-control" value="@ViewBag.DenNgay_Input" required />
                    <button type="submit" class="btn btn-primary">Thống kê</button>
                </div>
            </form>

            <table class="table table-bordered align-middle text-center">
                <thead class="table-light fw-bold">
                    <tr>
                        <th style="width: 5%">STT</th>
                        <th style="width: 15%">Mã sản phẩm</th>
                        <th>Tên sản phẩm</th>
                        <th style="width: 12%">Nhập</th>
                        <th style="width: 12%">Xuất</th>
                        <th style="width: 12%">Tồn</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model != null && Model.Any())
                    {
                        int stt = 1;
                        foreach (var item in Model)
                        {
                            <tr>
                                <td>@stt</td>
                                <td>@item.MaSanPham</td>
                                <td class="text-start">@item.TenSanPham</td>
                                <td>@item.TongNhap</td>
                                <td>@item.TongXuat</td>
                                <td class="fw-bold text-primary">@item.TonKho</td>
                            </tr>
                            stt++;
                        }
                    }
                    else
                    {
                        <tr><td colspan="6" class="text-muted py-3">Không có dữ liệu trong khoảng thời gian này</td></tr>
                    }
                </tbody>
            </table>

            <div class="row mt-5">
                <div class="col-12 d-flex justify-content-between align-items-end">
                    <div>
                        <label class="fw-bold">Người lập báo cáo:</label>
                        <input type="text" class="form-control border-bottom-only d-inline-block text-center" style="width: 200px;" value="@User.Identity?.Name" readonly />
                    </div>
                    <div>
                        <label class="fw-bold">Ngày</label>
                        <input type="text" class="form-control border-bottom-only d-inline-block text-center" style="width: 150px;" value="@DateTime.Now.ToString("dd/MM/yyyy")" readonly />
                    </div>
                </div>
            </div>

            <div class="text-center mt-4 d-print-none">
                <button onclick="window.print()" class="btn btn-secondary px-4"><i class="bi bi-printer"></i> In Báo Cáo</button>
            </div>
        </div>
    </div>
</div>
<style>
    .border-bottom-only {
        border: none;
        border-bottom: 1px dotted #000;
        background: transparent;
        border-radius: 0;
    }

    @@media print {
        .d-print-none {
            display: none !important;
        }

        .card {
            border: none;
            box-shadow: none;
        }
    }
</style>