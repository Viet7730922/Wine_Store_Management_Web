@model Wine_Store_Management_Web.Models.Hoadon

@{
    ViewData["Title"] = "Hóa Đơn BH_BM1";
    Layout = "_Layout"; 
}

<div class="container my-5 d-flex justify-content-center">
    <div style="width: 850px;">
        @* <p class="fw-bold mb-1" style="font-size: 1.1rem; color: #000;">1.2.2.5. BH_BM1</p> *@

        <div class="p-4 bg-white" style="border: 2px solid #000;">
            <div class="text-center mb-4">
                <h3 class="fw-bold m-0" style="color: #000;">HÓA ĐƠN BÁN HÀNG</h3>
                <p class="m-0 mt-2" style="font-size: 0.95rem;">
                    Mẫu số: <span class="text-primary">@Model.MauSo</span> /
                    Ký hiệu: <span class="text-primary">@Model.KyHieu</span> /
                    Số: <span class="text-primary fw-bold">@Model.SoHoaDon</span>
                </p>
                <p class="m-0" style="font-size: 0.95rem;">Ngày hóa đơn: ngày @Model.NgayHoaDon.Day tháng @Model.NgayHoaDon.Month năm @Model.NgayHoaDon.Year</p>
            </div>

            <div class="mb-4" style="line-height: 2;">
                <div class="d-flex"><span class="me-2">Đơn vị bán hàng:</span> <span class="border-dotted flex-grow-1">@Model.DonViBanHang</span></div>
                <div class="d-flex"><span class="me-2">Địa chỉ:</span> <span class="border-dotted flex-grow-1">@Model.DiaChiBanHang</span></div>
                <div class="d-flex"><span class="me-2">Điện thoại (Tel):</span> <span class="border-dotted flex-grow-1">@Model.DienThoaiBanHang</span></div>
                <div class="d-flex"><span class="me-2">Họ tên người mua hàng:</span> <span class="border-dotted flex-grow-1">@Model.HoTenNguoiMua</span></div>
                <div class="d-flex"><span class="me-2">Địa chỉ:</span> <span class="border-dotted flex-grow-1">@(string.IsNullOrEmpty(Model.DiaChiKhachHang) ? "..........................................................." : Model.DiaChiKhachHang)</span></div>

                <div class="d-flex align-items-center">
                    <span class="me-3">Hình thức thanh toán:</span>
                    <span class="fs-5 me-1">@(Model.HinhThucThanhToan == "Tiền mặt" ? "☑" : "☐")</span> Tiền mặt
                    <span class="fs-5 ms-3 me-1">@(Model.HinhThucThanhToan == "Chuyển Khoản" ? "☑" : "☐")</span> Chuyển Khoản
                </div>

                <div class="d-flex"><span class="me-2">Ghi chú:</span> <span class="border-dotted flex-grow-1">@(string.IsNullOrEmpty(Model.GhiChu) ? "..........................................................." : Model.GhiChu)</span></div>
            </div>

            <table class="table table-bordered border-dark text-center align-middle mb-0" style="border-width: 2px !important;">
                <thead>
                    <tr>
                        <th style="width: 5%">STT</th>
                        <th style="width: 15%">Mã sản phẩm</th>
                        <th>Tên sản phẩm</th>
                        <th style="width: 10%">ĐVT</th>
                        <th style="width: 10%">Số lượng</th>
                        <th style="width: 18%">Đơn giá</th>
                        <th style="width: 20%">Thành tiền</th>
                    </tr>
                </thead>
                <tbody>
                    @{
                        int stt = 1;
                        decimal tongTienGoc = 0;
                        foreach (var item in Model.ChitietHoadons)
                        {
                            var thanhTien = item.SoLuong * item.DonGia;
                            tongTienGoc += thanhTien;
                            <tr>
                                <td>@stt</td>
                                <td>@item.MaSanPham</td>
                                <td class="text-start">@(item.MaSanPhamNavigation?.TenSanPham ?? "N/A")</td>
                                <td>@(item.MaSanPhamNavigation?.DonViTinh ?? "Chai")</td>
                                <td>@item.SoLuong</td>
                                <td class="text-end">@item.DonGia.ToString("N0")</td>
                                <td class="text-end fw-bold">@thanhTien.ToString("N0")</td>
                            </tr>
                            stt++;
                        }

                        // Tính tổng sau giảm giá để hiển thị
                        decimal giamGia = 0;
                        if (Model.MaKhuyenMaiNavigation != null)
                        {
                            string numStr = new string(Model.MaKhuyenMaiNavigation.MucGiamGia.Where(char.IsDigit).ToArray());
                            if (decimal.TryParse(numStr, out decimal mucGiam))
                            {
                                giamGia = Model.MaKhuyenMaiNavigation.MucGiamGia.Contains("%") ? tongTienGoc * (mucGiam / 100) : mucGiam;
                            }
                        }
                        decimal tongThanhToan = tongTienGoc - giamGia;
                        if (tongThanhToan < 0) tongThanhToan = 0;
                    }
                </tbody>
            </table>

            <div class="border border-dark border-top-0 p-2 d-flex justify-content-between align-items-center" style="border-width: 2px !important;">
                <span class="fw-bold">Cộng tiền hàng hóa, dịch vụ:</span>
                <span class="fw-bold fs-5">
                    @if (giamGia > 0)
                    {
                        <del class="text-muted fw-normal fs-6 me-2">@tongTienGoc.ToString("N0")</del>
                    }
                    @tongThanhToan.ToString("N0") VNĐ
                </span>
            </div>

            <div class="mt-3">
                <span class="fst-italic d-inline-block mt-2">Số tiền bằng chữ: </span>
                <span class="border-dotted flex-grow-1 d-inline-block w-75 fst-italic">@Model.TongTienVietBangChu</span>
            </div>

            <div class="row text-center mt-5 mb-5 pb-4">
                <div class="col-6">
                    <p class="fw-bold m-0">Người mua hàng</p>
                    <small class="fst-italic">(Ký, ghi rõ họ tên)</small>
                </div>
                <div class="col-6">
                    <p class="fw-bold m-0">Người bán hàng</p>
                    <small class="fst-italic">(Ký, ghi rõ họ tên)</small>
                </div>
            </div>
        </div>

        <div class="text-center mt-4 d-print-none">
            <button onclick="window.print()" class="btn btn-secondary px-5 py-2 fw-bold"><i class="bi bi-printer"></i> In Mẫu BH_BM1</button>
            <a asp-action="Index" class="btn btn-outline-danger ms-3">Đóng lại</a>
        </div>
    </div>
</div>

<style>
    /* Đường chấm bi tạo cảm giác form điền tay */
    .border-dotted {
        border-bottom: 2px dotted #000;
        padding-left: 10px;
        font-weight: 500;
    }

    table th, table td {
        border-color: #000 !important;
    }

    /* Cấu hình ẩn menu Layout và margin thừa khi sử dụng lệnh In ấn (Ctrl+P) */
    @@media print {
        header, footer, .d-print-none {
            display: none !important;
        }

        .container {
            max-width: 100% !important;
            margin: 0 !important;
            padding: 0 !important;
        }

        body {
            background-color: #fff !important;
        }
    }
</style>