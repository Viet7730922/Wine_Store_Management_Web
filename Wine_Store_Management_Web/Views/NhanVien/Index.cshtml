@model IEnumerable<Wine_Store_Management_Web.Models.Nhanvien>

@{
    ViewData["Title"] = "Quản lý Nhân Viên (QLCH_BM1)";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3 class="text-primary">QUẢN LÝ TÀI KHOẢN NHÂN VIÊN</h3>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-person-plus"></i> Tạo Tài Khoản Mới</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body">
            <table class="table table-hover table-bordered align-middle text-center">
                <thead class="table-primary">
                    <tr>
                        <th>Mã NV</th>
                        <th>Họ Tên</th>
                        <th>Tên Đăng Nhập</th>
                        <th>Số Điện Thoại</th>
                        <th>Vai Trò</th>
                        <th>Trạng Thái</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td class="fw-bold">@item.MaNhanVien</td>
                            <td class="text-start">@item.HoTen</td>
                            <td>@item.TenDangNhap</td>
                            <td>@item.SoDienThoai</td>
                            <td>@item.VaiTro</td>
                            <td>
                                <span class="badge @(item.TrangThai == "Kích hoạt" ? "bg-success" : "bg-danger")">
                                    @item.TrangThai
                                </span>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>