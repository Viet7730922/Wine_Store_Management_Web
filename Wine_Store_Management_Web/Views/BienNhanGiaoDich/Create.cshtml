@model Wine_Store_Management_Web.Models.BiennhanGiaodich

@{
    ViewData["Title"] = "BH_BM6 - In Biên Nhận";
}

<div class="container mt-4 d-flex justify-content-center">
    <div class="card shadow-sm" style="width: 650px;">
        <div class="card-body p-4">
            <h4 class="text-center fw-bold mb-4">BIÊN NHẬN ĐỔI TRẢ HOẶC GIAO DỊCH</h4>

            <form asp-action="Create" method="post">
                <div class="row mb-3 text-center">
                    <div class="col-6">
                        <label class="fw-bold">Ngày in:</label>
                        <input asp-for="NgayIn" type="date" class="form-control form-control-sm d-inline w-50 border-bottom-only" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-6">
                        <label class="fw-bold">Giờ:</label>
                        <input asp-for="GioIn" type="time" class="form-control form-control-sm d-inline w-50 border-bottom-only" value="@DateTime.Now.ToString("HH:mm")" />
                    </div>
                </div>

                <div class="mb-3 d-flex align-items-center">
                    <label class="fw-bold me-3">Loại biên nhận:</label>
                    <div class="form-check me-3">
                        <input class="form-check-input" type="radio" asp-for="LoaiBienNhan" value="Đơn hàng chờ giao" id="lb1" checked>
                        <label class="form-check-label" for="lb1">[ ] Đơn hàng chờ giao</label>
                    </div>
                    <div class="form-check">
                        <input class="form-check-input" type="radio" asp-for="LoaiBienNhan" value="Biên nhận lấy hàng bảo hành" id="lb2">
                        <label class="form-check-label" for="lb2">[ ] Biên nhận lấy hàng bảo hành</label>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="fw-bold">Mã đối chiếu hệ thống:</label>
                    <input asp-for="MaDoiChieuHeThong" class="form-control border-bottom-only w-75 d-inline" placeholder="..............................................................................." />
                </div>

                <h6 class="fw-bold text-decoration-underline">NỘI DUNG BIÊN NHẬN:</h6>

                <div class="mb-2">
                    <label class="fw-bold">- Tên khách hàng:</label>
                    <input asp-for="TenKhachHang" class="form-control border-bottom-only w-75 d-inline" placeholder="........................................................................" />
                </div>

                <div class="mb-2">
                    <label class="fw-bold">- Số điện thoại:</label>
                    <input asp-for="SoDienThoai" class="form-control border-bottom-only w-75 d-inline" placeholder="............................................................................" />
                </div>

                <div class="mb-2">
                    <label class="fw-bold">- Chi tiết sản phẩm/Nội dung bàn giao:</label>
                    <textarea asp-for="ChiTietSanPham" class="form-control border-bottom-only w-100" rows="2" placeholder="......................................................................"></textarea>
                </div>

                <div class="mb-4 d-flex align-items-center">
                    <label class="fw-bold me-2">- Tổng giá trị đối chiếu (nếu có):</label>
                    <input asp-for="TongGiaTriDoiChieu" type="number" step="0.01" class="form-control border-bottom-only text-end" style="width: 150px;" placeholder="................................" />
                    <span class="ms-2 fw-bold">VNĐ</span>
                </div>

                <p class="fst-italic text-center mb-2">Biên nhận dùng để giao cho khách đối chiếu khi nhận hàng.</p>
                <hr style="border-top: 1px solid #000;" />

                <div class="text-end mt-3">
                    <label class="fw-bold">Người xuất phiếu (Thu ngân):</label>
                    <input asp-for="ThuNganXuatPhieu" class="form-control border-bottom-only d-inline w-50" placeholder="....................................................................." value="@User.Identity?.Name" />
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-secondary px-5"><i class="bi bi-printer"></i> Xác nhận & In</button>
                </div>
            </form>
        </div>
    </div>
</div>