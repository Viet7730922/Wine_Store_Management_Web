@model IEnumerable<Wine_Store_Management_Web.Models.PhieuBaohanhKho>

@{
    ViewData["Title"] = "Danh Sách Phiếu Bảo Hành Kho";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h4 class="text-dark fw-bold"><i class="bi bi-box-seam text-primary"></i> QUẢN LÝ PHIẾU BẢO HÀNH KHO</h4>
        <a asp-action="Create" class="btn btn-primary"><i class="bi bi-file-earmark-plus"></i> Lập Phiếu Bảo Hành</a>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert alert-success text-center fw-bold">@TempData["SuccessMessage"]</div>
    }

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-bordered align-middle text-center m-0">
                <thead class="table-primary">
                    <tr>
                        <th style="width: 14%">Mã phiếu</th>
                        <th style="width: 25%">Khách hàng</th>
                        <th style="width: 25%">Sản phẩm xử lý</th>
                        <th>Số Seri / Mã vạch</th>
                        <th style="width: 12%">Ngày hẹn trả</th>
                        <th style="width: 12%">Thao tác</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-muted p-4">Hệ thống chưa kết xuất phiếu bảo hành kho nào.</td>
                        </tr>
                    }
                    else
                    {
                        foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold text-primary">@item.MaPhieuBh</td>
                                <td class="text-start ps-3">
                                    <span class="fw-bold">@item.MaKhachHangNavigation?.HoTen</span> <br />
                                    <small class="text-muted">Mã KH: @item.MaKhachHang</small>
                                </td>
                                <td class="text-start ps-3">
                                    <span>@item.MaSanPhamNavigation?.TenSanPham</span> <br />
                                    <small class="text-muted">Mã SP: @item.MaSanPham</small>
                                </td>
                                <td class="text-monospace fw-bold text-secondary">@item.SoSeri</td>
                                <td>
                                    @{
                                        var treHan = item.NgayHenTra < DateOnly.FromDateTime(DateTime.Now);
                                    }
                                    <span class="badge @(treHan ? "bg-danger" : "bg-success")">
                                        @item.NgayHenTra.ToString("dd/MM/yyyy")
                                    </span>
                                </td>
                                
                                <td>
                                    <a asp-action="Details" asp-route-id="@item.MaPhieuBh" class="btn btn-sm btn-outline-dark">
                                        <i class="bi bi-printer"></i> Kết xuất / In
                                    </a>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>