@model Wine_Store_Management_Web.Models.HoaDon

@{
    ViewData["Title"] = "BH_BM1 - Lập Hóa Đơn Bán Hàng";
}

<div class="container mt-4">
    <div class="card shadow">
        <div class="card-body p-4">
            <div class="row mb-4 text-center text-md-start">
                <div class="col-md-8">
                    <h5 class="text-uppercase m-0">Cửa Hàng Rượu Chilliquer</h5>
                    <p class="small m-0">Số 138, đường Mai Xuân Thưởng, Phường Nha Trang, Khánh Hòa</p>
                    <p class="small m-0">Điện thoại (Tel): 0905XXXXXX</p>
                </div>
                <div class="col-md-4 text-md-end text-center">
                    <h4 class="text-danger font-weight-bold mb-1">HÓA ĐƠN BÁN HÀNG</h4>
                    <span class="d-block small">Mẫu số: ...... / Ký hiệu: ......</span>
                    <span class="d-block small">Số: <input asp-for="SoHoaDon" class="form-control form-control-sm d-inline-block w-50" placeholder="Nhập số HD" /></span>
                </div>
            </div>

            <form asp-action="Create" method="post">
                <div class="row g-3 mb-4">
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Ngày hóa đơn:</label>
                        <input asp-for="NgayHoaDon" type="date" class="form-control" value="@DateTime.Now.ToString("yyyy-MM-dd")" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Họ tên người mua hàng:</label>
                        <input asp-for="HoTenNguoiMua" class="form-control" placeholder="Nhập tên khách hàng" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Mã khách hàng thân thiết (Nếu có):</label>
                        <input asp-for="MaKhachHang" class="form-control" placeholder="Mã số thẻ..." />
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-bold">Địa chỉ:</label>
                        <input asp-for="DiaChiKhachHang" class="form-control" placeholder="Địa chỉ người mua" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Hình thức thanh toán:</label>
                        <div class="mt-2">
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" asp-for="HinhThucThanhToan" value="Tiền mặt" id="payCash" checked>
                                <label class="form-check-label" for="payCash">Tiền mặt</label>
                            </div>
                            <div class="form-check form-check-inline">
                                <input class="form-check-input" type="radio" asp-for="HinhThucThanhToan" value="Chuyển Khoản" id="payBank">
                                <label class="form-check-label" for="payBank">Chuyển Khoản</label>
                            </div>
                        </div>
                    </div>
                    <div class="col-md-8">
                        <label class="form-label fw-bold">Ghi chú:</label>
                        <input asp-for="GhiChu" class="form-control" placeholder="Ghi chú đơn hàng" />
                    </div>
                    <div class="col-md-4">
                        <label class="form-label fw-bold">Mã khuyến mãi áp dụng:</label>
                        <input asp-for="MaKhuyenMai" class="form-control" placeholder="Nhập mã ưu đãi" />
                    </div>
                </div>

                <h5 class="border-bottom pb-2 text-primary">CHI TIẾT HÀNG HÓA, DỊCH VỤ</h5>
                <table class="table table-bordered align-middle text-center" id="productTable">
                    <thead class="table-light">
                        <tr>
                            <th style="width: 5%">STT</th>
                            <th style="width: 15%">Mã sản phẩm</th>
                            <th>Tên sản phẩm</th>
                            <th style="width: 10%">ĐVT</th>
                            <th style="width: 12%">Số lượng</th>
                            <th style="width: 15%">Đơn giá</th>
                            <th style="width: 18%">Thành tiền</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>1</td>
                            <td><input name="ChiTietHoaDons[0].MaSanPham" class="form-control form-control-sm text-center" required /></td>
                            <td><input class="form-control form-control-sm text-start" readonly placeholder="Hệ thống tự load tên rượu" /></td>
                            <td><input class="form-control form-control-sm text-center" readonly /></td>
                            <td><input name="ChiTietHoaDons[0].SoLuong" type="number" class="form-control form-control-sm text-center" value="1" min="1" /></td>
                            <td><input name="ChiTietHoaDons[0].DonGia" type="number" step="0.01" class="form-control form-control-sm text-end" required /></td>
                            <td><input class="form-control form-control-sm text-end fw-bold" readonly value="0.00" /></td>
                        </tr>
                    </tbody>
                </table>

                <div class="row justify-content-end mb-4">
                    <div class="col-md-6 text-end">
                        <p class="fw-bold fs-5 m-0">Cộng tiền hàng hóa, dịch vụ: <span class="text-danger" id="txtTongTien">0.00</span> VNĐ</p>
                    </div>
                </div>

                <div class="mb-4">
                    <label class="form-label fw-bold">Số tiền bằng chữ:</label>
                    <input asp-for="TongTienVietBangChu" class="form-control" placeholder="Hệ thống tự động chuyển số thành chữ khi tính toán..." readonly />
                </div>

                <div class="row text-center mb-4 mt-5">
                    <div class="col-6">
                        <p class="fw-bold m-0">Người mua hàng</p>
                        <small class="text-muted d-block mb-5">(Ký, ghi rõ họ tên)</small>
                    </div>
                    <div class="col-6">
                        <p class="fw-bold m-0">Người bán hàng</p>
                        <small class="text-muted d-block mb-5">(Ký, ghi rõ họ tên)</small>
                        <input asp-for="ThuNgan" type="hidden" value="@User.Identity?.Name" />
                    </div>
                </div>

                <div class="text-center mt-4">
                    <button type="submit" class="btn btn-primary px-5 btn-lg">Tạo Hóa Đơn & In</button>
                    <a asp-action="Index" class="btn btn-secondary px-4 btn-lg">Quay lại danh sách</a>
                </div>
            </form>
        </div>
    </div>
</div>